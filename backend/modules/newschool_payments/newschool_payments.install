    'field_last_stripe_event_id' => [
      'storage' => [
        'field_name'  => 'field_last_stripe_event_id',
        'entity_type' => 'node',
        'type'        => 'string',
        'settings'    => ['max_length' => 255],
        'cardinality' => 1,
      ],
      'instance' => [
        'field_name'  => 'field_last_stripe_event_id',
        'entity_type' => 'node',
