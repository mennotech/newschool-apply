    'field_receipt_url' => [
      'storage' => [
        'field_name'  => 'field_receipt_url',
        'entity_type' => 'node',
        'type'        => 'string',
        'settings'    => ['max_length' => 2048],
        'cardinality' => 1,
      ],
      'instance' => [
        'field_name'  => 'field_receipt_url',
        'entity_type' => 'node',
