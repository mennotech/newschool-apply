<?php

/**
 * @file
 * Install, update, and uninstall hooks for the newschool_payments module.
 *
 * Creates the payment content type and all its fields programmatically so
 * the module is self-contained and does not require manual config import to
 * become functional.
 */

use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\node\Entity\NodeType;

/**
 * Implements hook_install().
 */
function newschool_payments_install() {
  // Create the payment node type if it does not already exist.
  if (!NodeType::load('payment')) {
    $node_type = NodeType::create([
      'type'        => 'payment',
      'name'        => 'Payment',
      'description' => 'Authoritative payment record for application fees.',
      'new_revision' => FALSE,
      'display_submitted' => FALSE,
    ]);
    $node_type->save();
  }

  _newschool_payments_create_fields();
}

/**
 * Implements hook_uninstall().
 */
function newschool_payments_uninstall() {
  // Remove field instances attached to the payment bundle.
  $field_names = [
    'field_application',
    'field_payer',
    'field_amount_cents',
    'field_currency',
    'field_status',
    'field_stripe_checkout_session_id',
    'field_stripe_payment_intent_id',
    'field_paid_at',
    'field_last_stripe_event_id',
    'field_receipt_url',
  ];

  foreach ($field_names as $field_name) {
    $instance = FieldConfig::loadByName('node', 'payment', $field_name);
    if ($instance) {
      $instance->delete();
    }
  }

  // Remove field storage definitions (only those unique to this module).
  $module_storage_fields = [
    'field_amount_cents',
    'field_currency',
    'field_status',
    'field_stripe_checkout_session_id',
    'field_stripe_payment_intent_id',
    'field_paid_at',
    'field_last_stripe_event_id',
    'field_receipt_url',
  ];

  foreach ($module_storage_fields as $field_name) {
    $storage = FieldStorageConfig::loadByName('node', $field_name);
    if ($storage) {
      $storage->delete();
    }
  }

  // Delete the payment node type.
  $node_type = NodeType::load('payment');
  if ($node_type) {
    $node_type->delete();
  }
}

/**
 * Creates all field storage and instance definitions for the payment bundle.
 */
function _newschool_payments_create_fields() {
  $fields = _newschool_payments_field_definitions();

  foreach ($fields as $field_name => $definition) {
    // Create field storage if it does not exist.
    if (!FieldStorageConfig::loadByName('node', $field_name)) {
      FieldStorageConfig::create($definition['storage'])->save();
    }

    // Create field instance on the payment bundle if it does not exist.
    if (!FieldConfig::loadByName('node', 'payment', $field_name)) {
      FieldConfig::create($definition['instance'])->save();
    }
  }
}

/**
 * Returns field storage and instance definitions for the payment content type.
 *
 * @return array
 *   Keyed by field machine name, each value has 'storage' and 'instance' keys.
 */
