      'instance' => [
        'field_name'  => 'field_status',
        'entity_type' => 'node',
        'bundle'      => 'payment',
        'label'       => 'Payment Status',
        'required'    => FALSE,
        'default_value' => [['value' => 'unpaid']],
      ],
    ],

    'field_stripe_checkout_session_id' => [
      'storage' => [
        'field_name'  => 'field_stripe_checkout_session_id',
        'entity_type' => 'node',
        'type'        => 'string',
        'settings'    => ['max_length' => 255],
        'cardinality' => 1,
      ],
      'instance' => [
        'field_name'  => 'field_stripe_checkout_session_id',
