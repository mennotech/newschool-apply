        'required'    => FALSE,
      ],
    ],

    'field_stripe_payment_intent_id' => [
      'storage' => [
        'field_name'  => 'field_stripe_payment_intent_id',
        'entity_type' => 'node',
        'type'        => 'string',
        'settings'    => ['max_length' => 255],
        'cardinality' => 1,
      ],
      'instance' => [
        'field_name'  => 'field_stripe_payment_intent_id',
        'entity_type' => 'node',
        'bundle'      => 'payment',
        'label'       => 'Stripe Payment Intent ID',
        'required'    => FALSE,
