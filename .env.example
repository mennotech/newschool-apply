# Drupal admin credentials
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=changeme

# Comma-separated is NOT supported — use a single origin or override per environment.
# Allowed CORS origin for the React frontend (no trailing slash).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base URL for the Drupal backend, used by the React frontend to make API requests.
DRUPAL_BASE_URL=http://localhost:8080