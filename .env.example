# Drupal admin credentials for local development.
DRUPAL_ADMIN_USER=admin
# Required: set a local-only admin password before starting the backend.
DRUPAL_ADMIN_PASS=

# Backend Stripe configuration. Leave blank unless testing payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional Drupal site display name.
DRUPAL_SITE_NAME=NewSchool Apply

# Canonical public URLs.
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Production-only override for allowing multiple frontend origins.
# Leave blank for local/dev so CORS follows FRONTEND_URL.
# Example: https://apply.school.edu,https://apply2.school.edu
CORS_ALLOWED_ORIGINS=